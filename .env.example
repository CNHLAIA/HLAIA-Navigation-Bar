# ---------- MySQL (NAS: 192.168.8.6) ----------
MYSQL_HOST=192.168.8.6
MYSQL_PORT=3306
MYSQL_DATABASE=hlaia_nav
MYSQL_USERNAME=hlaia
MYSQL_PASSWORD=hlaia123

# ---------- Redis (NAS: 192.168.8.6) ----------
REDIS_HOST=192.168.8.6
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- Kafka (NAS: 192.168.8.6) ----------
KAFKA_BOOTSTRAP_SERVERS=192.168.8.6:9092

# ---------- JWT ----------
JWT_SECRET=hlaia-navigation-bar-secret-key-must-be-at-least-256-bits-long-for-hs256-algorithm
JWT_ACCESS_TOKEN_EXPIRATION=86400000
JWT_REFRESH_TOKEN_EXPIRATION=604800000
