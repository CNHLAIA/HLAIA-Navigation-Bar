{
  "manifest_version": 3,
  "name": "HLAIA Navigation Bar",
  "version": "1.0.0",
  "description": "Quick-save web pages to your HLAIA navigation bar",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "notifications"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "http://192.168.8.6:13566/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
